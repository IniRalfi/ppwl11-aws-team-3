# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# Menggunakan format connection string.
# Untuk development (lokal sqlite): "file:./dev.db"
# Untuk production (seperti Turso libSQL): "libsql://<hostname>[...]"
DATABASE_URL="file:./dev.db"

# Token autentikasi database Turso (wajib di production, biarkan kosong untuk dev lokal)
DB_AUTH_TOKEN=

# ==========================================
# FRONTEND INTEGRATION
# ==========================================
# URL Frontend untuk keperluan routing/CORS
FRONTEND_URL="http://localhost:5173"

# ==========================================
# GOOGLE OAUTH CONFIGURATION
# ==========================================
# Credentials dari Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Pastikan port/URL redirect sama seperti yang didaftarkan di Google Console
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/callback"

# ==========================================
# SECURITY & AUTHENTICATION
# ==========================================
# Digunakan untuk enkripsi session (bisa diisi random string atau UUID panjang)
SESSION_SECRET=

# API Key spesifik untuk keperluan endpoint privat/internal aplikasi kamu
API_KEY="test-api-key"
